@{
    ViewData["Title"] = "Gestión SAE";
}

<div class="component-header">
    <h1><i class="fas fa-gear"></i> Gestión SAE</h1>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-cog"></i> Configuración y Gestión</h5>
            </div>
            <div class="card-body">
                <p>Módulo de Gestión SAE</p>
                <p>Funcionalidades a definir:</p>
                <ul>
                    <li>Configuración del Sistema Automático de Energía</li>
                    <li>Monitoreo de parámetros</li>
                    <li>Control de dispositivos</li>
                    <li>Logs y auditoría</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .component-header {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--accent-color);
    }

    .component-header h1 {
        color: var(--text-primary);
        font-size: 32px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .component-header i {
        color: var(--accent-color);
        font-size: 36px;
    }
</style>
