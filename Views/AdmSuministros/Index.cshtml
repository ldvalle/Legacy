@{
    ViewData["Title"] = "Administración de Suministros";
}

<div class="component-header">
    <h1><i class="fas fa-boxes"></i> Administración de Suministros</h1>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-plus-circle"></i> Gestión de Suministros</h5>
            </div>
            <div class="card-body">
                <p>Módulo de Administración de Suministros</p>
                <p>Funcionalidades a definir:</p>
                <ul>
                    <li>Gestión de inventario de suministros</li>
                    <li>Registros de compras y provisiones</li>
                    <li>Control de almacenes</li>
                    <li>Reportes de consumo</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .component-header {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--accent-color);
    }

    .component-header h1 {
        color: var(--text-primary);
        font-size: 32px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .component-header i {
        color: var(--accent-color);
        font-size: 36px;
    }
</style>
