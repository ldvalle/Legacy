@{
    ViewData["Title"] = "Gestión de Órdenes de Trabajo";
}

<div class="component-header">
    <h1><i class="fas fa-tasks"></i> Gestión de Órdenes de Trabajo (OTs)</h1>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-clipboard-list"></i> Gestión de OTs</h5>
            </div>
            <div class="card-body">
                <p>Módulo de Gestión de Órdenes de Trabajo</p>
                <p>Funcionalidades a definir:</p>
                <ul>
                    <li>Creación y seguimiento de órdenes de trabajo</li>
                    <li>Asignación de tareas a técnicos</li>
                    <li>Control de estados y tiempos</li>
                    <li>Reportes de ejecución</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .component-header {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--accent-color);
    }

    .component-header h1 {
        color: var(--text-primary);
        font-size: 32px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .component-header i {
        color: var(--accent-color);
        font-size: 36px;
    }
</style>
