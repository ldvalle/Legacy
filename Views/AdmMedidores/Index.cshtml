@{
    ViewData["Title"] = "Administración de Medidores";
}

<div class="component-header">
    <h1><i class="fas fa-tachometer-alt"></i> Administración de Medidores</h1>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-barcode"></i> Gestión de Medidores</h5>
            </div>
            <div class="card-body">
                <p>Módulo de Administración de Medidores</p>
                <p>Funcionalidades a definir:</p>
                <ul>
                    <li>Registro y catalogación de medidores</li>
                    <li>Control de calibración</li>
                    <li>Historial de lecturas</li>
                    <li>Mantenimiento y reemplazo</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .component-header {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--accent-color);
    }

    .component-header h1 {
        color: var(--text-primary);
        font-size: 32px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .component-header i {
        color: var(--accent-color);
        font-size: 36px;
    }
</style>
