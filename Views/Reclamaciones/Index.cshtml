@{
    ViewData["Title"] = "Gestión de Reclamaciones";
}

<div class="component-header">
    <h1><i class="fas fa-file-alt"></i> Gestión de Reclamaciones</h1>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-exclamation-circle"></i> Registro de Reclamaciones</h5>
            </div>
            <div class="card-body">
                <p>Módulo de Gestión de Reclamaciones</p>
                <p>Funcionalidades a definir:</p>
                <ul>
                    <li>Registro de reclamaciones de clientes</li>
                    <li>Seguimiento de casos</li>
                    <li>Asignación a departamentos</li>
                    <li>Reportes de resolución</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .component-header {
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--accent-color);
    }

    .component-header h1 {
        color: var(--text-primary);
        font-size: 32px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .component-header i {
        color: var(--accent-color);
        font-size: 36px;
    }
</style>
